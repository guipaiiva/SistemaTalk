# ============================================================
# .env.example — Template de variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores
# ============================================================

# ── JWT ─────────────────────────────────────────────────────
SECRET_KEY=sua-chave-secreta-aqui

# ── API Microvix (Linx) ──────────────────────────────────────
MICROVIX_URL=https://webapi.microvix.com.br/1.0/api/integracao
MICROVIX_USER=seu-usuario
MICROVIX_SENHA=sua-senha
MICROVIX_CHAVE=sua-chave-aqui

# ── Evolution API (WhatsApp) ─────────────────────────────────
EVOLUTION_URL=https://sua-evolution-api.com
EVOLUTION_KEY=sua-api-key-aqui
EVOLUTION_INSTANCIA=nome-da-instancia
